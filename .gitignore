# Data directories (too large for GitHub — notebooks re-download from NREL)
data/raw/
data/processed/
data/metadata/

# Model checkpoints and training outputs
outputs/checkpoints/
outputs/logs/
outputs/results/*.csv
*.pt
*.pth
*.ckpt

# But DO keep the colab_outputs/ folder (trained Notebook 1 artifacts, ~30MB)
# These let Notebooks 2-5 skip the 4-6hr VAE training step.
!colab_outputs/**/*.pt
!colab_outputs/**/*.npy
!colab_outputs/**/*.csv
!colab_outputs/**/*.parquet

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Virtual environments
venv/
env/
.venv/
.env

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# LaTeX build artifacts
paper/*.aux
paper/*.log
paper/*.out
paper/*.synctex.gz
paper/*.toc
paper/*.bbl
paper/*.blg
paper/*.fls
paper/*.fdb_latexmk

# Jupyter checkpoints
*.ipynb_checkpoints

# Weights & Biases
wandb/

# Temporary files
*.tmp
*.bak
*.old
tool-results/
